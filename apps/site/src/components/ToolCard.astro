---
import type { Tool } from '../lib/tools';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;

const riskColors: Record<string, string> = {
  low: 'chip-risk-low',
  medium: 'chip-risk-medium',
  high: 'chip-risk-high',
  critical: 'chip-risk-critical',
};

function hashTool(value: string) {
  let hash = 0;
  for (let index = 0; index < value.length; index += 1) {
    hash = (hash * 31 + value.charCodeAt(index)) >>> 0;
  }
  return hash.toString(16).toUpperCase().slice(0, 5).padStart(5, '0');
}
---

<a href={`/tools/${tool.slug}`} class="terminal-card group flex min-h-[260px] flex-col p-5">
  <div class="mb-5 flex items-start justify-between gap-4 border-b border-outline-variant pb-4">
    <div class="min-w-0 text-code text-muted-variant">
      ID: <span class="font-bold text-primary">0x{hashTool(tool.slug)}</span><span class="cursor-blink-sm"></span>
    </div>
    <span class={`chip ${riskColors[tool.risk] ?? 'chip-default'}`}>{tool.risk}</span>
  </div>

  <h3 class="mb-3 truncate text-title font-bold text-primary transition-colors group-hover:text-acid">{tool.binary}</h3>
  <p class="mb-6 line-clamp-3 min-h-[64px] text-body text-muted-variant">{tool.description}</p>

  <div class="mt-auto grid grid-cols-2 gap-3 border border-outline-variant bg-background p-3 text-code">
    <div>
      <div class="mb-1 text-[10px] uppercase tracking-[0.14em] text-muted">[CATEGORY]</div>
      <div class="truncate font-bold text-primary">{tool.category[0] ?? 'uncategorized'}</div>
    </div>
    <div>
      <div class="mb-1 text-[10px] uppercase tracking-[0.14em] text-muted">[LANG]</div>
      <div class="truncate font-bold text-primary">{tool.lang.includes('all') ? 'all' : tool.lang.slice(0, 2).join('/')}</div>
    </div>
  </div>

  <div class="mt-4 flex flex-wrap gap-1.5">
    {tool.category.slice(0, 2).map((cat) => <span class="chip chip-default">{cat}</span>)}
    {tool.effects?.slice(0, 2).map((effect) => <span class="chip chip-default">{effect}</span>)}
  </div>
</a>
