---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { getLocaleFromUrl, t } from '../lib/i18n';

const locale = getLocaleFromUrl(Astro.url);
---

<Layout title={t(locale, 'agents.metaTitle')}>
  <Header locale={locale} />

  <main class="terminal-shell z-10 px-4 py-12 sm:px-6">
    <section class="mb-10 border-b border-outline-variant pb-8">
      <div class="label-caps mb-4">{t(locale, 'agents.label')}</div>
      <h1 class="mb-3 text-[40px] font-extrabold tracking-[-0.05em] text-primary sm:text-5xl">{t(locale, 'agents.title')}</h1>
      <p class="max-w-2xl border-l-2 border-acid pl-4 text-body text-muted-variant">
        {t(locale, 'agents.body')}
      </p>
    </section>

    <div class="grid grid-cols-1 gap-[1px] border border-outline-variant bg-outline-variant shadow-hard lg:grid-cols-2">
      <section class="bg-surface-dim p-6 lg:col-span-2">
        <div class="panel-header -mx-6 -mt-6 mb-6"><span>{t(locale, 'agents.principles')}</span><span>{t(locale, 'agents.rules')}</span></div>
        <ol class="grid gap-4 md:grid-cols-5">
          {[
            ['01', t(locale, 'agents.rule.1.title'), t(locale, 'agents.rule.1.body')],
            ['02', t(locale, 'agents.rule.2.title'), t(locale, 'agents.rule.2.body')],
            ['03', t(locale, 'agents.rule.3.title'), t(locale, 'agents.rule.3.body')],
            ['04', t(locale, 'agents.rule.4.title'), t(locale, 'agents.rule.4.body')],
            ['05', t(locale, 'agents.rule.5.title'), t(locale, 'agents.rule.5.body')],
          ].map(([num, title, body]) => (
            <li class="border border-outline-variant bg-background p-4">
              <div class="mb-4 text-headline font-extrabold text-acid">{num}</div>
              <h2 class="mb-2 text-body font-bold text-primary">{title}</h2>
              <p class="text-code text-muted-variant">{body}</p>
            </li>
          ))}
        </ol>
      </section>

      <section class="bg-surface-dim p-6">
        <div class="panel-header -mx-6 -mt-6 mb-6"><span>{t(locale, 'agents.effects')}</span><span>{t(locale, 'agents.risk')}</span></div>
        <div class="space-y-3 text-body">
          {[
            [t(locale, 'agents.safe'), 'read_files', t(locale, 'agents.effect.read_files'), 'chip-risk-low'],
            [t(locale, 'agents.caution'), 'write_files', t(locale, 'agents.effect.write_files'), 'chip-risk-medium'],
            [t(locale, 'agents.caution'), 'execute_code', t(locale, 'agents.effect.execute_code'), 'chip-risk-medium'],
            [t(locale, 'agents.danger'), 'network_access', t(locale, 'agents.effect.network_access'), 'chip-risk-high'],
            [t(locale, 'agents.danger'), 'secret_exposure', t(locale, 'agents.effect.secret_exposure'), 'chip-risk-critical'],
          ].map(([level, code, text, chip]) => (
            <div class="flex items-start gap-3 border border-outline-variant bg-background p-3">
              <span class={`chip ${chip}`}>{level}</span>
              <span class="text-muted-variant"><code class="text-primary">{code}</code> — {text}</span>
            </div>
          ))}
        </div>
      </section>

      <section class="bg-surface-dim p-6">
        <div class="panel-header -mx-6 -mt-6 mb-6"><span>{t(locale, 'agents.interface')}</span><span>{t(locale, 'agents.cli')}</span></div>
        <p class="mb-4 text-body text-muted-variant">{t(locale, 'agents.interface.body')}</p>
        <pre class="overflow-x-auto border border-outline-variant bg-background p-4 text-code text-primary"><code>{`runbook scan
runbook prefer
runbook category search --lang rust
runbook category test --lang python`}</code></pre>
      </section>

      <section class="bg-surface-dim p-6 lg:col-span-2">
        <div class="panel-header -mx-6 -mt-6 mb-6"><span>{t(locale, 'agents.flow')}</span><span>{t(locale, 'agents.closedLoop')}</span></div>
        <div class="grid gap-3 text-body md:grid-cols-3">
          {[t(locale, 'agents.step.category'), t(locale, 'agents.step.language'), t(locale, 'agents.step.availability'), t(locale, 'agents.step.risk'), t(locale, 'agents.step.guardrails'), t(locale, 'agents.step.confirmation')].map((step, index) => (
            <div class="border border-outline-variant bg-background p-4">
              <span class="label-caps text-acid">STEP_{String(index + 1).padStart(2, '0')}</span>
              <p class="mt-2 font-bold uppercase text-primary">{step}</p>
            </div>
          ))}
        </div>
      </section>
    </div>
  </main>
</Layout>
