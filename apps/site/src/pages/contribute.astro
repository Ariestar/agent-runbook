---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { getLocaleFromUrl, t } from '../lib/i18n';

const locale = getLocaleFromUrl(Astro.url);
---

<Layout title={t(locale, 'contribute.metaTitle')}>
  <Header locale={locale} />

  <main class="terminal-shell z-10 px-4 py-12 sm:px-6">
    <section class="mb-10 border-b border-outline-variant pb-8">
      <div class="label-caps mb-4">{t(locale, 'contribute.label')}</div>
      <div class="mb-3 flex flex-wrap items-center justify-between gap-4">
        <h1 class="text-[40px] font-extrabold tracking-[-0.05em] text-primary sm:text-5xl">{t(locale, 'contribute.title')}</h1>
        <a
          href="https://github.com/Ariestar/awesome-agent-cli/new/main/data/tools"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-acid bg-acid/10 px-4 py-2 text-sm font-bold text-acid transition-colors hover:bg-acid/20"
        >
          <span>+</span>
          <span>{t(locale, 'contribute.addTool')}</span>
        </a>
      </div>
      <p class="max-w-2xl border-l-2 border-acid pl-4 text-body text-muted-variant">
        {t(locale, 'contribute.body')}
      </p>
    </section>

    <div class="grid grid-cols-1 gap-[1px] border border-outline-variant bg-outline-variant shadow-hard lg:grid-cols-2">
      <section class="bg-surface-dim p-6">
        <div class="panel-header -mx-6 -mt-6 mb-6"><span>{t(locale, 'contribute.acceptance')}</span><span>{t(locale, 'contribute.goodFit')}</span></div>
        <ul class="space-y-3 text-body text-muted-variant">
          {[
            t(locale, 'contribute.good.1'),
            t(locale, 'contribute.good.2'),
            t(locale, 'contribute.good.3'),
            t(locale, 'contribute.good.4'),
          ].map((item) => <li class="border border-acid/30 bg-acid/5 p-3"><span class="text-acid">✓</span> {item}</li>)}
        </ul>
      </section>

      <section class="bg-surface-dim p-6">
        <div class="panel-header -mx-6 -mt-6 mb-6"><span>{t(locale, 'contribute.rejection')}</span><span>{t(locale, 'contribute.notFit')}</span></div>
        <ul class="space-y-3 text-body text-muted-variant">
          {[
            t(locale, 'contribute.bad.1'),
            t(locale, 'contribute.bad.2'),
            t(locale, 'contribute.bad.3'),
            t(locale, 'contribute.bad.4'),
          ].map((item) => <li class="border border-danger/40 bg-danger/5 p-3"><span class="text-danger">✕</span> {item}</li>)}
        </ul>
      </section>

      <section class="bg-surface-dim p-6 lg:col-span-2">
        <div class="panel-header -mx-6 -mt-6 mb-6"><span>{t(locale, 'contribute.sequence')}</span><span>{t(locale, 'contribute.steps')}</span></div>
        <ol class="grid gap-3 md:grid-cols-4">
          {[t(locale, 'contribute.step.1'), t(locale, 'contribute.step.2'), t(locale, 'contribute.step.3'), t(locale, 'contribute.step.4')].map((item, index) => (
            <li class="border border-outline-variant bg-background p-4">
              <div class="mb-4 text-headline font-extrabold text-acid">{String(index + 1).padStart(2, '0')}</div>
              <p class="text-body text-primary">{item}</p>
            </li>
          ))}
        </ol>
      </section>

      <section class="bg-surface-dim p-6 lg:col-span-2">
        <div class="panel-header -mx-6 -mt-6 mb-6"><span>{t(locale, 'contribute.template')}</span><span>{t(locale, 'contribute.spec')}</span></div>
        <pre class="overflow-x-auto border border-outline-variant bg-background p-4 text-code text-primary"><code>{`name: my-tool
binary: my-tool
aliases: []
category:
  - search
lang:
  - all
summary: "One-line description of what it does."
homepage: "https://github.com/..."
docs: "https://..."
detect:
  version_args: ["--version"]
use_when:
  - "Scenario where an agent should pick this tool"
avoid_when:
  - "Scenario where another tool is better"
guardrails:
  - "Safety advice for agents using this tool"
risk:
  level: medium
  effects:
    - read_files
    - write_files
  requires_auth: false
  destructive: false`}</code></pre>
      </section>
    </div>
  </main>
</Layout>
